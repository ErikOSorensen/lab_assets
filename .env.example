# RF Lab Assets — Environment Configuration
# Copy this file to .env and edit the values.

# REQUIRED: Secret key for Django session/CSRF security.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me

# Admin account created on first start
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=changeme
DJANGO_SUPERUSER_EMAIL=admin@localhost

# Hostnames and IPs that can reach the app (comma-separated).
# Include your LXC/server IP and any DNS name you use.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins — full URLs with scheme and port (comma-separated).
# Required for any host other than localhost.
# Example: http://lab-assets.local:8000,http://192.168.1.50:8000
DJANGO_CSRF_TRUSTED_ORIGINS=

# Database password (internal, between app and database containers)
POSTGRES_PASSWORD=lab_assets_dev

# Port exposed on the host
WEB_PORT=8000
